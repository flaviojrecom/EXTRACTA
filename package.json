{
  "name": "extracta",
  "version": "0.1.0",
  "description": "AI-Powered Knowledge Extraction Engine — Transform documents into AI-ready knowledge",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "extracta": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:cli": "tsup",
    "build:web": "next build web",
    "dev": "tsx src/cli/index.ts",
    "dev:web": "next dev web",
    "start:web": "next start web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "web": "next dev web -p 3000",
    "extracta": "node dist/index.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:build": "storybook build"
  },
  "keywords": [
    "extracta",
    "document-extraction",
    "rag",
    "ai",
    "pdf",
    "epub",
    "chunking",
    "knowledge-base"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "canvas": "^3.2.1",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^13.1.0",
    "embla-carousel-react": "^8.6.0",
    "js-tiktoken": "^1.0.21",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.8.69",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/addon-themes": "^10.2.16",
    "@storybook/nextjs-vite": "10.2.16",
    "@storybook/test": "^8.6.15",
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "eslint-plugin-storybook": "10.2.16",
    "prettier": "^3.5.0",
    "storybook": "^10.2.16",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
